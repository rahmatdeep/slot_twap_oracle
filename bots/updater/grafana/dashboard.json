{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Successful Updates (rate/min)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "auto"
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(updates_successful_total[5m]) * 60",
          "legendFormat": "successful/min",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Failed & Skipped Updates (rate/min)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "auto"
          },
          "unit": "ops"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(updates_failed_total[5m]) * 60",
          "legendFormat": "failed/min",
          "refId": "A"
        },
        {
          "expr": "rate(updates_skipped_total[5m]) * 60",
          "legendFormat": "skipped/min",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Update Totals",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "failed" },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "red", "value": 1 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "stale" },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "orange", "value": 1 }
                  ]
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "updates_successful_total",
          "legendFormat": "successful",
          "refId": "A"
        },
        {
          "expr": "updates_failed_total",
          "legendFormat": "failed",
          "refId": "B"
        },
        {
          "expr": "updates_skipped_total",
          "legendFormat": "skipped",
          "refId": "C"
        },
        {
          "expr": "stale_oracles_total",
          "legendFormat": "stale",
          "refId": "D"
        }
      ]
    },
    {
      "title": "Last Update Slot per Oracle",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 5,
            "pointSize": 5,
            "showPoints": "auto"
          },
          "unit": "none",
          "decimals": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "oracle_last_update_slot",
          "legendFormat": "{{ pair }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Staleness Alerts (rate/5m)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 50,
            "pointSize": 5,
            "showPoints": "never"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "increase(stale_oracles_total[5m])",
          "legendFormat": "stale detections",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Oracle Slot Lag (current slot - last update)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Requires a 'solana_current_slot' metric or manual recording. Shows how far behind each oracle is.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "auto",
            "thresholdsStyle": { "mode": "line" }
          },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "max(oracle_last_update_slot) - oracle_last_update_slot",
          "legendFormat": "{{ pair }} lag",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["solana", "oracle", "twap"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "label": "Prometheus",
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Slot TWAP Oracle - Updater Bot",
  "uid": "slot-twap-oracle-updater",
  "version": 1
}
